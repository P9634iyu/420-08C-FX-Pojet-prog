<Window x:Class="FrackSport.Views.SelectionEquipe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrackSport.Views"
        mc:Ignorable="d"
        Title="SelectionEquipe" Height="450" Width="800">
    <Grid>
        <Image Source="/Resources/Images/Fond.png" Stretch="Fill" Panel.ZIndex="0"/>
        <StackPanel Panel.ZIndex="1" Margin="10">
            <TextBlock x:Name="txbTitreLigue"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,10"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Height="380">
                <WrapPanel x:Name="wpEquipes"
                           HorizontalAlignment="Center"/>
            </ScrollViewer>
            <Button Content="Fermer"
                    Width="100"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Click="btnFermer_Click"/>
        </StackPanel>
    </Grid>
</Window>
