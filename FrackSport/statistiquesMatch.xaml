<Window x:Class="FrackSport.statistiquesMatch"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FrackSport"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="statistiquesMatch">

    <Grid>
        <Image Source="/Resources/Images/Fond.png" Stretch="Fill" Panel.ZIndex="0"/>
        <StackPanel Panel.ZIndex="1" Margin="16">

            <!-- Titre match -->
            <TextBlock x:Name="txbTitreMatch"
                       FontSize="18" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,4"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
            <TextBlock x:Name="txbDateMatch"
                       FontSize="13"
                       Foreground="LightGray"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,14"/>

            <!-- Stats -->
            <ScrollViewer Height="380" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="spStats" Margin="8,0"/>
            </ScrollViewer>

            <Button Content="Fermer" Width="100" Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Click="btnFermer_Click"/>
        </StackPanel>
    </Grid>
</Window>
