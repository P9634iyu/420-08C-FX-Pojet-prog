<Window x:Class="FrackSport.CalendrierEquipe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrackSport"
        mc:Ignorable="d"
        Title="CalendrierEquipe" Height="450" Width="800">
    <Grid>
        <Image Source="/Resources/Images/Fond.png" Stretch="Fill" Panel.ZIndex="0"/>
        <StackPanel Panel.ZIndex="1" Margin="16">

            <!-- Titre -->
            <TextBlock x:Name="txbTitreEquipe"
                       FontSize="20" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,16"/>

            <!-- Onglets Passés / À venir -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Button x:Name="btnPassés" Content="Matchs passés"
                        Width="140" Height="34" Margin="4,0"
                        Click="btnPassés_Click"/>
                <Button x:Name="btnAvenir" Content="Matchs à venir"
                        Width="140" Height="34" Margin="4,0"  Click="btnAvenir_Click"/>
            </StackPanel>

            <!-- Liste des matchs -->
            <ScrollViewer Height="380" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="spMatchs"/>
            </ScrollViewer>

            <Button Content="Fermer" Width="100" Margin="0,10,0,0"    HorizontalAlignment="Center" Click="btnFermer_Click"/>
        </StackPanel>
    </Grid>

</Window>
